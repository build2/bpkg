.include common.testscript config.testscript

cfg_create += 2>!

+$cfg_create -d acfg --name shared &acfg/***

clone_acfg = cp -pr ../acfg ./

# @@ To verify the creation result use cfg-list command rather than
#    pkg-status, when implemented.
#
pkg_status += -d cfg

: success
:
{
  $clone_cfg;
  $clone_acfg;

  $* acfg 2>>/~%EOE%;
    %associated target configuration .+/acfg/%
    EOE

  # Test that the name clash is discovered.
  #
  $* acfg 2>>EOE != 0;
    error: configuration with name 'shared' is already associated
      info: consider specifying name explicitly with --name|-n
    EOE

  # Test that the name path is discovered.
  #
  $* --name shared2 acfg 2>>/~%EOE% != 0;
    %error: configuration with path '.+/acfg/' is already associated: shared%
    EOE

  # Associate the second configuration.
  #
  cp -pr acfg acfg2;

  $* --name shared2 acfg2 2>>/~%EOE%;
    %associated target configuration .+/acfg2/%
    EOE

  $pkg_status libfoo >'libfoo unknown'
}
